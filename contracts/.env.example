# .env.example - Copy this to .env and fill in your values

# Deployer private key (without 0x prefix)
# IMPORTANT: Use a test wallet with SepoliaETH - never use mainnet funds!
PRIVATE_KEY=your_private_key_here

# RPC URLs (get free keys from https://dashboard.alchemy.com)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
ZKSYNC_RPC_URL=https://sepolia.era.zksync.dev
ARBITRUM_RPC_URL=https://arb-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# Etherscan/Arbiscan API Key (for verification)
ETHERSCAN_API_KEY=your_etherscan_api_key
